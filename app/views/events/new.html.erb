<h1>Events#new</h1>
<p>Find me in app/views/events/new.html.erb</p>

<h1>New Event</h1>

<%= form_with model: @event do |f| %>
  <p>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </p>

  <p>
    <%= f.label :description %><br>
    <%= f.text_area :description %>
  </p>

  <p>
    <%= f.label :date %><br>
    <%= f.datetime_select :date %>
  </p>

  <p>
    <%= f.label :location %><br>
    <%= f.text_field :location %>
  </p>

  <%= f.submit %>
<% end %>
