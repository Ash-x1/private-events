<h1>Events#show</h1>
<p>Find me in app/views/events/show.html.erb</p>

<h1><%= @event.title %></h1>

<p><%= @event.description %></p>
<p>Date: <%= @event.date %></p>
<p>Location: <%= @event.location %></p>
<p>Created by: <%= @event.creator.email %></p>

<h2>Attendees</h2>

<% @event.attendees.each do |attendee| %>
  <p><%= attendee.email %></p>
<% end %>

<% if user_signed_in? %>
  <%= button_to "Attend Event",
        event_attendances_path(@event),
        method: :post %>
<% end %>


<% if current_user == @event.creator %>
  <h3>Invite User</h3>

  <%= form_with url: event_attendances_path(@event), method: :post do |f| %>
    <%= select_tag :attendee_id,
          options_from_collection_for_select(User.all, :id, :email) %>
    <%= submit_tag "Invite" %>
  <% end %>
<% end %>
