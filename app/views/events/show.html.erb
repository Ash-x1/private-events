<h1>Events#show</h1>
<p>Find me in app/views/events/show.html.erb</p>

<h1><%= @event.title %></h1>

<p><%= @event.description %></p>
<p>Date: <%= @event.date %></p>
<p>Location: <%= @event.location %></p>
<p>Created by: <%= @event.creator.email %></p>

<h2>Attendees</h2>

<% @event.attendees.each do |attendee| %>
  <p><%= attendee.email %></p>
<% end %>

<% if user_signed_in? %>
  <%= button_to "Attend Event",
        event_event_attendances_path(@event),
        method: :post %>
<% end %>
